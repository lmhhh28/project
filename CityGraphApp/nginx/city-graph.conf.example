# 根据你的实际域名、证书和 listen 端口调整。
# 这里假设 Docker Compose 已经把前后端分别绑定到：
#   127.0.0.1:5173 -> city-graph-web
#   127.0.0.1:8080 -> city-graph-api

upstream city_graph_web {
    server 127.0.0.1:5173;
}

upstream city_graph_api {
    server 127.0.0.1:8080;
}

server {
    listen 80;
    server_name your-domain.example.com;

    location /api/ {
        proxy_pass http://city_graph_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://city_graph_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
